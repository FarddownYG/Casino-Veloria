# --- Server ---
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed CORS origins (frontend)
CORS_ORIGINS=http://localhost:5173

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/veloria?schema=public

# --- Redis (sessions, BullMQ, leaderboard cache) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# --- Economy / game tuning ---
SIGNUP_BONUS=1000
REFERRAL_REWARD_REFERRER=100
REFERRAL_REWARD_REFERRED=200
DAILY_STREAK_BONUS=50
GIFT_DAILY_LIMIT=5000
BANK_LOAN_THRESHOLD=200
BANK_LOAN_GRACE_DAYS=7
BANK_LOAN_DAILY_INTEREST=0.10
