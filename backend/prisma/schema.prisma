// VELORIA – Prisma schema
// Fake-money casino platform. All monetary values are VELORIA COINS (VC),
// stored as integers. No real-world value.
//
// Anti-cheat principle: balances and all gain/loss logic live server-side.
// Every balance mutation MUST be accompanied by an immutable Transaction row.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum Rank {
  BRONZE
  SILVER
  GOLD
  DIAMOND
}

// Signed ledger entry types. amount > 0 = credit, amount < 0 = debit.
enum TransactionType {
  SIGNUP_BONUS
  REFERRAL_BONUS_REFERRER
  REFERRAL_BONUS_REFERRED
  DAILY_STREAK
  BET_PLACED // debit when a wager leaves the balance
  BET_PAYOUT // credit when a winning bet pays out
  BET_REFUND
  BANK_LOAN_DISBURSEMENT
  BANK_LOAN_REPAYMENT
  BANK_LOAN_INTEREST
  P2P_LOAN_DISBURSEMENT
  P2P_LOAN_RECEIVED
  P2P_LOAN_REPAYMENT_OUT
  P2P_LOAN_REPAYMENT_IN
  P2P_LOAN_PENALTY
  GIFT_SENT
  GIFT_RECEIVED
  ADMIN_ADJUSTMENT
}

enum GameType {
  ROULETTE
  BLACKJACK
  POKER
}

enum BankLoanStatus {
  ACTIVE
  REPAID
  DEFAULTED
}

enum P2PLoanStatus {
  PROPOSED
  NEGOTIATING
  ACCEPTED
  REPAID
  DEFAULTED
  REJECTED
  CANCELLED
}

enum TableStatus {
  WAITING
  IN_PROGRESS
  CLOSED
}

enum NotificationType {
  GENERIC
  GAIN
  LOSS
  LOAN_RECEIVED
  LOAN_REPAYMENT_DUE
  LOAN_OVERDUE
  P2P_LOAN_OFFER
  P2P_LOAN_ACCEPTED
  P2P_LOAN_REJECTED
  P2P_LOAN_NEGOTIATION
  GIFT_RECEIVED
  RANK_UP
  STREAK_BONUS
  REFERRAL_REWARD
}

// ---------------------------------------------------------------------------
// CORE
// ---------------------------------------------------------------------------

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  passwordHash String? // null for OAuth-only accounts (e.g. Google via Supabase)
  role         Role    @default(USER)

  // OAuth (Supabase / Google)
  supabaseUserId String? @unique
  avatarUrl      String?

  // Economy
  balance Int @default(1000) // VC; starting bonus applied via SIGNUP_BONUS tx

  // Lifetime aggregates (drive leaderboards + ranks)
  totalWagered Int @default(0)
  totalWon     Int @default(0)
  totalLost    Int @default(0)
  netGains     Int @default(0) // totalWon - totalLost

  rank Rank @default(BRONZE)

  // Referral
  referralCode String  @unique
  referredById String?
  referredBy   User?   @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]  @relation("UserReferrals")
  referralLocked Boolean @default(false)

  // Engagement
  loginStreak        Int       @default(0)
  lastLoginAt        DateTime?
  lastStreakRewardAt DateTime?

  // Preferences
  soundEnabled Boolean @default(true)

  // RGPD
  ageVerifiedAt    DateTime?
  marketingConsent Boolean   @default(false)
  deletedAt        DateTime? // soft delete (right to erasure anonymises PII)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  transactions        Transaction[]
  bankLoans           BankLoan[]
  loansGiven          P2PLoan[]       @relation("P2PLender")
  loansReceived       P2PLoan[]       @relation("P2PBorrower")
  giftsSent           Gift[]          @relation("GiftSender")
  giftsReceived       Gift[]          @relation("GiftRecipient")
  referralRecord      Referral?       @relation("ReferralReferred")
  referralsMade       Referral[]      @relation("ReferralReferrer")
  notifications       Notification[]
  gamePlayers         GamePlayer[]
  bets                Bet[]
  refreshTokens       RefreshToken[]
  createdTables       GameTable[]     @relation("TableCreator")

  @@index([balance])
  @@index([netGains])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

// Immutable ledger. Rows are append-only; never updated or deleted.
model Transaction {
  id           String          @id @default(uuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id])
  type         TransactionType
  amount       Int // signed
  balanceAfter Int
  gameType     GameType?
  refId        String? // FK-ish to loan / round / gift / bet
  description  String?
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([userId, createdAt])
  @@index([type])
  @@map("transactions")
}

// ---------------------------------------------------------------------------
// LOANS
// ---------------------------------------------------------------------------

// Bank loan: available when balance < 200 VC. Amounts 500/1000/2500.
// 7 calendar days to repay, then 10% interest per extra day.
model BankLoan {
  id                 String         @id @default(uuid())
  userId             String
  user               User           @relation(fields: [userId], references: [id])
  principal          Int
  interestAccrued    Int            @default(0)
  amountDue          Int // principal + interestAccrued - repaid
  amountRepaid       Int            @default(0)
  status             BankLoanStatus @default(ACTIVE)
  dueDate            DateTime // disbursedAt + 7 days
  daysOverdue        Int            @default(0)
  lastInterestRunAt  DateTime?
  disbursedAt        DateTime       @default(now())
  repaidAt           DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([userId, status])
  @@index([status, dueDate])
  @@map("bank_loans")
}

// Player-to-player loan with negotiable interest + duration.
model P2PLoan {
  id            String        @id @default(uuid())
  lenderId      String
  lender        User          @relation("P2PLender", fields: [lenderId], references: [id])
  borrowerId    String
  borrower      User          @relation("P2PBorrower", fields: [borrowerId], references: [id])
  amount        Int
  interestRate  Float // percent over the whole duration
  durationDays  Int
  amountDue     Int           @default(0) // computed on acceptance
  amountRepaid  Int           @default(0)
  penaltyRate   Float         @default(0) // extra percent if defaulted
  status        P2PLoanStatus @default(PROPOSED)
  // Negotiation: each counter-offer appended here.
  negotiation   Json?
  dueDate       DateTime?
  acceptedAt    DateTime?
  repaidAt      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([borrowerId, status])
  @@index([lenderId, status])
  @@index([status, dueDate])
  @@map("p2p_loans")
}

// Direct gift (no interest, no acceptance). Limited to 5000 VC/day per sender.
model Gift {
  id          String   @id @default(uuid())
  senderId    String
  sender      User     @relation("GiftSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User     @relation("GiftRecipient", fields: [recipientId], references: [id])
  amount      Int
  message     String?
  createdAt   DateTime @default(now())

  @@index([senderId, createdAt])
  @@index([recipientId, createdAt])
  @@map("gifts")
}

// ---------------------------------------------------------------------------
// REFERRAL
// ---------------------------------------------------------------------------

model Referral {
  id              String   @id @default(uuid())
  referrerId      String
  referrer        User     @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referredId      String   @unique
  referred        User     @relation("ReferralReferred", fields: [referredId], references: [id])
  codeUsed        String
  rewardReferrer  Int      @default(100)
  rewardReferred  Int      @default(200)
  locked          Boolean  @default(true) // irreversible once applied
  createdAt       DateTime @default(now())

  @@index([referrerId])
  @@map("referrals")
}

// ---------------------------------------------------------------------------
// GAMES
// ---------------------------------------------------------------------------

// A persistent room a player can join. Roulette uses a single shared lobby
// table; Blackjack & Poker tables are created by players and auto-removed when
// empty for 3 minutes (BullMQ job).
model GameTable {
  id             String      @id @default(uuid())
  type           GameType
  name           String
  minBet         Int         @default(10)
  maxBet         Int         @default(1000)
  maxSeats       Int         @default(6)
  status         TableStatus @default(WAITING)
  isPersistent   Boolean     @default(false) // true for the shared roulette table
  createdById    String?
  createdBy      User?       @relation("TableCreator", fields: [createdById], references: [id])
  // Engine-specific live state (hands, deck, dealer, blinds, board...).
  state          Json?
  config         Json?
  lastActivityAt DateTime    @default(now())
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  players  GamePlayer[]
  sessions GameSession[]
  rounds   GameRound[]

  @@index([type, status])
  @@index([lastActivityAt])
  @@map("game_tables")
}

// Membership of a user at a table (seat, current stack for poker/bj).
model GamePlayer {
  id        String    @id @default(uuid())
  tableId   String
  table     GameTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  seat      Int
  stack     Int       @default(0)
  isActive  Boolean   @default(true)
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  @@unique([tableId, seat])
  @@unique([tableId, userId])
  @@index([userId])
  @@map("game_players")
}

// A player's participation span in a game (for history / analytics).
model GameSession {
  id        String    @id @default(uuid())
  userId    String
  gameType  GameType
  tableId   String?
  table     GameTable? @relation(fields: [tableId], references: [id])
  buyIn     Int        @default(0)
  cashOut   Int        @default(0)
  net       Int        @default(0)
  startedAt DateTime   @default(now())
  endedAt   DateTime?

  @@index([userId])
  @@map("game_sessions")
}

// One resolved round. Provably-fair fields let the RNG be audited.
model GameRound {
  id             String     @id @default(uuid())
  gameType       GameType
  tableId        String?
  table          GameTable? @relation(fields: [tableId], references: [id])
  // Provably fair RNG
  serverSeed     String
  serverSeedHash String
  clientSeed     String?
  nonce          Int        @default(0)
  result         Json // e.g. roulette { number, color }, bj/poker final state
  createdAt      DateTime   @default(now())

  bets Bet[]

  @@index([gameType, createdAt])
  @@index([tableId])
  @@map("game_rounds")
}

// A single wager within a round.
model Bet {
  id        String    @id @default(uuid())
  roundId   String
  round     GameRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  gameType  GameType
  betType   String // e.g. "STRAIGHT", "RED", "DOZEN_1"
  selection Json // numbers covered / hand action context
  stake     Int
  payout    Int       @default(0)
  won       Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([roundId])
  @@map("bets")
}

// ---------------------------------------------------------------------------
// LEADERBOARD / CASINO STATS
// ---------------------------------------------------------------------------

// Singleton-ish ledger of how much the house has won (sum of net player
// losses). Updated atomically on each settled round. id is always "global".
model CasinoStat {
  id              String   @id @default("global")
  totalEarnings   Int      @default(0) // net VC won by the house
  totalWagered    Int      @default(0)
  totalPaidOut    Int      @default(0)
  roundsPlayed    Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@map("casino_stats")
}

// Periodic snapshots (for charts / history). Live values come from Redis cache.
model LeaderboardSnapshot {
  id          String   @id @default(uuid())
  type        String // "WEALTH" | "GAINS" | "CASINO"
  data        Json
  generatedAt DateTime @default(now())

  @@index([type, generatedAt])
  @@map("leaderboard_snapshots")
}

// ---------------------------------------------------------------------------
// NOTIFICATIONS
// ---------------------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType @default(GENERIC)
  title     String
  body      String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}
