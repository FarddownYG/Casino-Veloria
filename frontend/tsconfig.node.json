{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // `composite` forces emit; redirect it to a throwaway dir so `tsc -b` never
    // writes a vite.config.js next to vite.config.ts (Vite resolves the .js
    // first, which would silently shadow edits to the .ts source of truth).
    "outDir": "./node_modules/.tmp/tsconfig-node"
  },
  "include": ["vite.config.ts"]
}
